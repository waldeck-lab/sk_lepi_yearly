# settings.env
if [[ -z "${YEAR:-}" ]]; then
    echo "Error: YEAR environment variable is not set." >&2
    echo "Please deskcheck and run 'source config/settings.env' and retry." >&2
    return 1
fi

SKLEPI_ROOT=$(git rev-parse --show-toplevel)
ROOT_DIR="${SKLEPI_ROOT}"
export SKLEPI_ROOT="$ROOT_DIR"
export SKLEPI_DB_DIR="${ROOT_DIR}/db"
export SKLEPI_DB_PATH="${SKLEPI_DB_DIR}/obsperyear.sqlite"
export SKLEPI_SQL_DIR="${ROOT_DIR}/sql"
export SKLEPI_SRC_DIR="${ROOT_DIR}/src"
export SKLEPI_LOG_DIR="${ROOT_DIR}/logs"
export SKLEPI_OUTPUT_DIR="${ROOT_DIR}/output"
export SKLEPI_TAXONOMY_DIR="${ROOT_DIR}/dwca"
export SCRIPT_DIR="${ROOT_DIR}/scripts"

mkdir -p "$SKLEPI_DB_DIR" "$SKLEPI_LOG_DIR" "$SKLEPI_OUTPUT_DIR"

if [[ -f "${ROOT_DIR}/config/settings.env" ]]; then
    set -a
    source "${ROOT_DIR}/config/settings.env"
    set +a
fi


echo "Environments are set"
